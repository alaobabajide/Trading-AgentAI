# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Alpaca (paper trading) ──────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # swap for live

# ── Binance (testnet) ───────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true                                # false for mainnet

# ── On-chain ────────────────────────────────────────────────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# ── Brain ───────────────────────────────────────────────────
SIGNAL_CONFIDENCE_THRESHOLD=0.7
BRAIN_PORT=8000

# ── Risk ────────────────────────────────────────────────────
MAX_POSITION_PCT=0.05          # max 5 % NAV per position
MAX_CRYPTO_ALLOCATION_PCT=0.30 # global 30 % crypto cap
CIRCUIT_BREAKER_DRAWDOWN=0.10  # halt if daily drawdown > 10 %

# ── Telegram Bot ────────────────────────────────────────────
# Get token from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to use the bot (leave blank = open to all)
# Find your chat ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_IDS=

# ── Monitoring ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=trading123
